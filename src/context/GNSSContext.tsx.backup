import React, {
  createContext,
  useContext,
  useEffect,
  useMemo,
  useRef,
  useState,
  useCallback,
} from "react";

import {
  ConnectionState,
  SurveyState,
  GNSSStatus,
  StreamState,
  Configuration,
  WiFiNetwork,
  BLEDevice,
  LogEntry,
  SurveyHistoryEntry,
  AppSettings,
  Satellite,
} from "../types/gnss";

import { api, WS_URL } from "../api/gnssApi";
import { scanWifi, connectWifi } from "../native/wifi";
import { uiLogger } from "../utils/uiLogger";

/* ================= CONTEXT TYPE ================= */

type GNSSContextType = {
  connection: ConnectionState;
  connectToDevice: (type: "wifi" | "ble", identifier: string, password?: string) => Promise<void>;
  disconnect: () => void;
  survey: SurveyState;
  startSurvey: () => Promise<void>;
  stopSurvey: () => Promise<void>;
  isAutoFlowActive: boolean;
  startAutoFlow: (durationSec: number, accuracyM: number, ntripConfig?: any) => Promise<void>;
  stopAutoFlow: () => Promise<void>;
  gnssStatus: GNSSStatus;
  streams: StreamState;
  configuration: Configuration;
  updateConfiguration: (config: Configuration) => Promise<void>;
  settings: AppSettings;
  updateSettings: (settings: AppSettings) => Promise<void>;
  availableWiFiNetworks: WiFiNetwork[];
  availableBLEDevices: BLEDevice[];
  scanWiFi: () => Promise<void>;
  scanBLE: () => Promise<void>;
  surveyHistory: SurveyHistoryEntry[];
  logs: LogEntry[];
  addLog: (level: 'error' | 'warning' | 'info', message: string) => void;
  clearLogs: () => void;
  exportHistoryCSV: () => Promise<void>;
  exportLogsCSV: () => Promise<void>;
  // NTRIP control functions
  startNTRIP: (host: string, port: number, mountpoint: string, password: string, username?: string) => Promise<void>;
  stopNTRIP: () => Promise<void>;
};

const GNSSContext = createContext<GNSSContextType | null>(null);

export const useGNSS = () => {
  const ctx = useContext(GNSSContext);
  if (!ctx) throw new Error("useGNSS must be used inside GNSSProvider");
  return ctx;
};

/* ================= PROVIDER ================= */

export const GNSSProvider: React.FC<{ children: React.ReactNode }> = ({ children }) => {
  const wsRef = useRef<WebSocket | null>(null);
  const stoppingRef = useRef(false);
  const intentionalDisconnectRef = useRef(false); // Track if user intentionally disconnected

  /* ================= STATE ================= */

  const [connection, setConnection] = useState<ConnectionState>({
    connectionType: "none",
    isConnected: false,
    lastConnectedTimestamp: null,
    signalStrength: 0,
    latency: 0,
    autoReconnect: true,
  });

  const [survey, setSurvey] = useState<SurveyState>({
    surveyMode: "survey-in",
    isActive: false,
    valid: false,
    progress: 0,
    elapsedTime: 0,
    requiredTime: 120,
    currentAccuracy: 0,
    targetAccuracy: 100,
    position: { latitude: 0, longitude: 0, altitude: 0, accuracy: 0 },
    localCoordinates: { meanX: 0, meanY: 0, meanZ: 0, observations: 0 },
    status: "idle",
    satelliteCount: 0,
  });

  const [surveyCompleted, setSurveyCompleted] = useState(false);

  const [isAutoFlowActive, setIsAutoFlowActive] = useState(false);

  const [gnssStatus, setGNSSStatus] = useState<GNSSStatus>({
    satellites: [],
    fixType: "none",
    dop: { hdop: null, vdop: null, pdop: null },
    updateRate: 1,
    lastUpdate: new Date(),
    firmwareVersion: "unknown",
    activeConstellations: [],
    globalPosition: { latitude: 0, longitude: 0, altitude: 0, horizontalAccuracy: 0 },
  });

  const defaultStream = { enabled: false, active: false, throughput: 0, messageRate: 0 };
  const [streams, setStreams] = useState<StreamState>({
    serial: { ...defaultStream },
    ntrip: { ...defaultStream, mountpoint: "", uptime: 0, dataSent: 0, lastError: null },
    tcp: { ...defaultStream, connectedClients: 0 },
    udp: { ...defaultStream },
  });

  const [availableWiFiNetworks, setAvailableWiFiNetworks] = useState<WiFiNetwork[]>([]);
  const [availableBLEDevices, setAvailableBLEDevices] = useState<BLEDevice[]>([]);
  const [surveyHistory, setSurveyHistory] = useState<SurveyHistoryEntry[]>([]);
  const [logs, setLogs] = useState<LogEntry[]>([]);

  const [configuration, setConfiguration] = useState<Configuration>({
    baseStation: {
      surveyDuration: 120,
      accuracyThreshold: 100,
      autoStart: false,
      autoMode: false,
      fixedMode: { enabled: false, coordinates: survey.position },
    },
    streams: {
      ntrip: { server: "caster.emlid.com", port: 2101, mountpoint: "", username: "", password: "" },
      serial: { baudRate: 115200, messages: [], rates: [] },
      tcp: { port: 9000, maxClients: 5, authEnabled: false },
      udp: { port: 8001, broadcastAddress: "", multicast: false },
    },
    system: { wifiSsid: "", wifiPassword: "", ledMode: "status", ledBrightness: 80 },
  });

  const [settings, setSettings] = useState<AppSettings>({
    units: { distance: "meters", coordinates: "DD" },
    theme: "system",
    language: "en",
    notifications: { surveyCompletion: true, connectionLoss: true, lowAccuracy: true, sound: true, vibration: true },
    connection: { preferredMethod: "auto", autoReconnect: true, timeout: 10, keepScreenAwake: true },
  });

  // Helper functions defined early to avoid dependency issues
  const addLog = (level: 'error' | 'warning' | 'info', message: string) => {
    setLogs((prev) => [{id: Date.now().toString(), timestamp: new Date(), level, message}, ...prev].slice(0, 500));
  };

  /* ================= WEBSOCKET ================= */

  const connectWebSocket = useCallback(() => {
    if (wsRef.current?.readyState === WebSocket.OPEN) return;

    wsRef.current = new WebSocket(WS_URL);

    wsRef.current.onopen = () => {
      setConnection((prev) => ({ ...prev, isConnected: true, lastConnectedTimestamp: new Date() }));
    };

    wsRef.current.onmessage = (event) => {
      try {
        const data = JSON.parse(event.data);

        const satellites: Satellite[] = Array.from(
          { length: data.gnss?.num_satellites || 0 },
          (_, i) => ({ id: i, constellation: "GPS", elevation: 0, azimuth: 0, snr: 0, used: true })
        );

        setGNSSStatus({
          satellites,
          fixType: data.gnss?.fix_type ?? "none",
          dop: { hdop: data.gnss?.hdop ?? null, vdop: data.gnss?.vdop ?? null, pdop: data.gnss?.pdop ?? null },
          updateRate: data.gnss?.update_rate_hz ?? 1,
          lastUpdate: new Date(),
          firmwareVersion: data.system?.firmware_version ?? "unknown",
          activeConstellations: ["GPS"],
          globalPosition: {
            latitude: data.gnss?.latitude ?? 0,
            longitude: data.gnss?.longitude ?? 0,
            altitude: data.gnss?.altitude_msl ?? 0,
            horizontalAccuracy: data.gnss?.horizontal_accuracy ?? 0,
          },
        });

        if (data.autoflow !== undefined) {
           setIsAutoFlowActive(data.autoflow.active ?? false);
        }

        setSurvey((prev) => {
          const wsActive = data.survey?.active ?? false;
          const wsValid = data.survey?.valid ?? false;
          
          // If we're in stopping state, completely ignore incoming WebSocket updates about survey status
          // This prevents the WebSocket from overriding our local stop decision
          if (stoppingRef.current) {
            return prev; // Don't update survey status while stopping
          }

          const wsAccuracy = (data.survey?.accuracy_m ?? 0) * 100;
          
          if (wsActive && !prev.isActive) {
             return {
                ...prev,
                isActive: true,
                status: "in-progress",
                elapsedTime: data.survey?.progress_seconds ?? 0,
                currentAccuracy: wsAccuracy,
                satelliteCount: data.gnss?.num_satellites ?? 0,
             };
          }

          if (prev.isActive) {
             const shouldUpdateAccuracy = wsAccuracy > 0 && wsAccuracy < 5000; 
             const accuracyMet = wsAccuracy > 0 && wsAccuracy <= prev.targetAccuracy;
             const timeMet = prev.elapsedTime >= prev.requiredTime;
             
             // Check if survey should be marked as valid based on accuracy or time
             const shouldBeValid = (wsValid || accuracyMet || timeMet);
             
             return {
               ...prev,
               satelliteCount: data.gnss?.num_satellites ?? prev.satelliteCount,
               currentAccuracy: shouldUpdateAccuracy ? wsAccuracy : prev.currentAccuracy,
               position: {
                 latitude: data.gnss?.latitude ?? prev.position.latitude,
                 longitude: data.gnss?.longitude ?? prev.position.longitude,
                 altitude: data.gnss?.altitude_msl ?? prev.position.altitude,
                 accuracy: data.gnss?.horizontal_accuracy ?? prev.position.accuracy,
               },
               localCoordinates: {
                 meanX: data.survey?.mean_x_m ?? prev.localCoordinates.meanX,
                 meanY: data.survey?.mean_y_m ?? prev.localCoordinates.meanY,
                 meanZ: data.survey?.mean_z_m ?? prev.localCoordinates.meanZ,
                 observations: data.survey?.observations ?? prev.localCoordinates.observations,
               },
               isActive: wsActive, 
               status: !wsActive ? (prev.status === 'completed' ? 'completed' : 'stopped') : prev.status, // Preserve completed status
               // Mark as valid if accuracy or time requirements are met, but don't stop automatically
               valid: shouldBeValid
             };
          } 
          
          return prev;
        });

      } catch (e) {
        console.error("WebSocket parse error:", e);
      }
    };

    wsRef.current.onclose = () => {
      // Only set disconnected if user intentionally clicked disconnect
      // Otherwise, try to reconnect automatically
      if (intentionalDisconnectRef.current) {
        intentionalDisconnectRef.current = false; // Reset flag
        setConnection((prev) => ({ ...prev, isConnected: false }));
      } else {
        // Unintended disconnect - will trigger auto-reconnect
      }
    };
  }, []);

  useEffect(() => {
    connectWebSocket();
    
    // Reconnect if WebSocket disconnects and survey is not active
    // Only reconnect if disconnect was not intentional
    const reconnectTimer = setInterval(() => {
      const wsDown = wsRef.current?.readyState !== WebSocket.OPEN;
      const surveyInactive = !survey.isActive;
      const notIntentionalDisconnect = !intentionalDisconnectRef.current;
      
      if (wsDown && surveyInactive && notIntentionalDisconnect && connection.isConnected) {
        connectWebSocket();
      }
    }, 5000);
    
    return () => {
      clearInterval(reconnectTimer);
    };
  }, [connectWebSocket, survey.isActive, connection.isConnected]);

  /* ================= CONFIG SYNC (FIX 1) ================= */
  // Immediately update the RUNNING survey targets when configuration changes
  useEffect(() => {
    if (survey.isActive) {
      setSurvey((prev) => ({
        ...prev,
        requiredTime: configuration.baseStation.surveyDuration,
        targetAccuracy: configuration.baseStation.accuracyThreshold,
      }));
    }
  }, [configuration.baseStation.surveyDuration, configuration.baseStation.accuracyThreshold, survey.isActive]);


  /* ================= STOP SURVEY (FIX 2) ================= */
  const stopSurvey = useCallback(async () => {
    try {
      addLog('info', `Stopping survey`);
      stoppingRef.current = true; // Lock before anything else

      // Optimistic Stop - set UI to stopped immediately
      setSurvey((prev) => ({ ...prev, isActive: false, valid: false, status: 'stopped' }));
      
      // Try to stop with retries for resilience
      let stopAttempts = 0;
      let stopSucceeded = false;
      const maxRetries = 2;
      
      while (stopAttempts < maxRetries && !stopSucceeded) {
        try {
          stopAttempts++;
          await api.stopSurvey();
          stopSucceeded = true;
          addLog('info', 'Survey stopped successfully on backend');
        } catch (apiError) {
          if (stopAttempts < maxRetries) {
            console.warn(`Stop attempt ${stopAttempts}/${maxRetries} failed, retrying...`, apiError);
            addLog('warning', `Stop attempt ${stopAttempts}/${maxRetries} failed, retrying...`);
            // Wait 500ms before retry
            await new Promise(resolve => setTimeout(resolve, 500));
          } else {
            // Final attempt failed - but UI is already stopped locally
            console.warn(`All ${maxRetries} stop attempts failed:`, apiError);
            addLog('warning', `Backend stop failed after ${maxRetries} attempts (UI stopped locally): ${String(apiError)}`);
          }
        }
      }
      
      // Save History on success
      const historyEntry: SurveyHistoryEntry = {
        id: `survey_${Date.now()}`,
        timestamp: new Date(),
        duration: survey.elapsedTime,
        finalAccuracy: survey.currentAccuracy,
        targetAccuracy: survey.targetAccuracy,
        accuracyAttempts: [],
        coordinates: survey.position,
        success: survey.currentAccuracy <= survey.targetAccuracy,
      };
      setSurveyHistory((prev) => [historyEntry, ...prev]);

    } catch (error) {
      // Unexpected error - still force stop UI
      console.error("Unexpected error during survey stop:", error);
      addLog('error', `Unexpected survey stop error: ${String(error)}`);
      setSurvey((prev) => ({ ...prev, isActive: false, status: 'stopped' }));

    } finally {
      // Wait longer before unlocking to ensure WebSocket messages don't override our stop
      // Also give the backend time to process the stop before we accept new updates
      setTimeout(() => { 
        stoppingRef.current = false; 
    if (survey.valid && !survey.isActive && !streams.ntrip.active) {
      const ntripConfig = configuration.streams.ntrip;
      
      // Only auto-start if NTRIP is configured with required fields
      if (ntripConfig.server && ntripConfig.port && ntripConfig.mountpoint) {
        const startNTRIPAsync = async () => {
          try {
            addLog('info', `Auto-starting NTRIP after survey validation...`);
            
            await api.startNTRIP(
              ntripConfig.server,
              ntripConfig.port,
              ntripConfig.mountpoint,
              ntripConfig.password,
              ntripConfig.username
            );
            
            addLog('info', `NTRIP started successfully - broadcasting RTK corrections`);
          } catch (error) {
            const errorMsg = error instanceof Error ? error.message : String(error);
            addLog('error', `NTRIP auto-start failed: ${errorMsg}`);
          }
        };
        
        startNTRIPAsync();
      } else {
        addLog('warning', 'NTRIP not configured for auto-start. Missing server/port/mountpoint');
      }
  }
}, [survey.isActive, survey.elapsedTime, survey.requiredTime, surveyCompleted, stopSurvey]);

// Survey timer - stops when survey is completed
useEffect(() => {
  if (!survey.isActive || surveyCompleted) {
    return;
  }
  
  const surveyInterval = setInterval(() => {
    setSurvey((prev) => {
      const newElapsedTime = prev.elapsedTime + 1;
      const progress = Math.min(newElapsedTime / prev.requiredTime, 1);
      return { ...prev, elapsedTime: newElapsedTime, progress: progress };
    });
  }, 1000);
  
  return () => clearInterval(surveyInterval);
}, [survey.isActive, surveyCompleted]);

/* ================= TIMERS & AUTO START ================= */
// Poll survey status from backend every 2 seconds as backup to WebSocket
useEffect(() => {
  if (!survey.isActive) return;
  // ... rest of the code remains the same ...
    const pollInterval = setInterval(async () => {
      try {
        const surveyStatus = await api.getSurvey();
        if (surveyStatus) {
          setSurvey((prev) => {
            if (!stoppingRef.current) {
              const pollAccuracy = (surveyStatus.accuracy_m ?? 0) * 100; // m to cm
              return {
                ...prev,
                elapsedTime: surveyStatus.progress_seconds ?? prev.elapsedTime,
                currentAccuracy: pollAccuracy > 0 ? pollAccuracy : prev.currentAccuracy,
                isActive: surveyStatus.active ?? prev.isActive,
              };
            }
            return prev;
          });
        }
      } catch (e) {
        console.warn("Survey status poll failed:", e);
      }
    }, 2000);
    
    return () => clearInterval(pollInterval);
  }, [survey.isActive]);

  useEffect(() => {
    if (!survey.isActive || surveyCompleted) {
      return;
    }
    
    const surveyInterval = setInterval(() => {
      setSurvey((prev) => {
        // Don't update if survey is completed
        if (surveyCompleted) {
          return prev;
        }
        
        const newElapsedTime = prev.elapsedTime + 1;
        const progress = Math.min(newElapsedTime / prev.requiredTime, 1);
        return { ...prev, elapsedTime: newElapsedTime, progress: progress };
      });
    }, 1000);
    
    return () => clearInterval(surveyInterval);
  }, [survey.isActive, surveyCompleted, survey.requiredTime]);

  useEffect(() => {
    if (configuration.baseStation.autoMode && !survey.isActive && connection.isConnected && !stoppingRef.current) {
        const timer = setTimeout(() => {
            startSurvey().catch(err => {
                console.error("Auto start failed", err);
                addLog('error', `Auto start failed: ${String(err)}`);
            });
        }, 500); // Small delay to prevent race conditions
        return () => clearTimeout(timer);
    }
  }, [configuration.baseStation.autoMode, connection.isConnected, startSurvey, survey.isActive]);


  // --- OTHER ACTIONS ---
  const startAutoFlow = async () => {
    try {
        const duration = configuration.baseStation.surveyDuration;
        const accuracy = configuration.baseStation.accuracyThreshold / 100; // Convert cm to m
        const ntripConfig = {
            host: configuration.streams.ntrip.server,
            port: configuration.streams.ntrip.port,
            mountpoint: configuration.streams.ntrip.mountpoint,
            username: configuration.streams.ntrip.username,
            password: configuration.streams.ntrip.password,
        };
        
        addLog('info', `Starting Auto Flow: ${duration}s / ${accuracy}m with NTRIP`);
        
        await api.startAutoFlow(duration, accuracy, ntripConfig);
        setIsAutoFlowActive(true);
        addLog('info', 'Auto Flow started successfully');
    } catch (error) {
        addLog('error', `Auto Flow start failed: ${String(error)}`);
        throw error;
    }
  };

  const stopAutoFlow = async () => {
    try {
        addLog('info', 'Stopping Auto Flow');
        await api.stopAutoFlow();
        setIsAutoFlowActive(false);
        addLog('info', 'Auto Flow stopped successfully');
    } catch (error) {
        addLog('error', `Auto Flow stop failed: ${String(error)}`);
        throw error;
    }
  };

  const updateConfiguration = async (config: Configuration) => {
    setConfiguration(config);
  };

  const updateSettings = async (patch: Partial<AppSettings>) => {
    setSettings((prev) => ({ ...prev, ...patch }));
  };
  const clearLogs = () => setLogs([]);
  const exportHistoryCSV = async () => { };
  const exportLogsCSV = async () => { };

  const value = useMemo(
    () => ({
      connection, connectToDevice, disconnect,
      survey, startSurvey, stopSurvey,
      isAutoFlowActive, startAutoFlow, stopAutoFlow,
      gnssStatus, streams,
      configuration, updateConfiguration,
      settings, updateSettings,
      availableWiFiNetworks, availableBLEDevices, scanWiFi, scanBLE,
      surveyHistory, logs, addLog, clearLogs, exportHistoryCSV, exportLogsCSV,
      // NTRIP control functions
      startNTRIP: api.startNTRIP,
      stopNTRIP: api.stopNTRIP,
    }),
    [connection, survey, isAutoFlowActive, gnssStatus, streams, configuration, settings, surveyHistory, logs, startSurvey, stopSurvey]
  );

  return (
    <GNSSContext.Provider value={value}>
      {children}
    </GNSSContext.Provider>
  );
};























































